{
  "name": "bookmarked",
  "description": "A tiny (dependency free!) library for building bookmark files.",
  "version": "3.0.9",
  "author": "Ollie Williams",
  "bugs": "https://github.com/pxlprfct/bookmarked/issues",
  "devDependencies": {
    "@arethetypeswrong/cli": "0.18.2",
    "@changesets/cli": "2.30.0",
    "@commitlint/cli": "20.5.0",
    "@commitlint/config-conventional": "20.5.0",
    "@eslint/js": "10.0.1",
    "@types/node": "25.6.0",
    "@vitest/coverage-v8": "3.2.4",
    "@vitest/ui": "3.2.4",
    "conventional-changelog-conventionalcommits": "9.3.1",
    "eslint": "10.2.0",
    "husky": "9.1.7",
    "knip": "6.4.1",
    "lint-staged": "16.4.0",
    "prettier": "3.8.3",
    "syncpack": "14.3.0",
    "tsup": "8.5.1",
    "typescript": "5.9.3",
    "typescript-eslint": "8.58.2",
    "vitest": "3.2.4"
  },
  "exports": {
    "./package.json": "./package.json",
    ".": {
      "import": "./dist/index.js",
      "default": "./dist/index.cjs"
    }
  },
  "files": [
    "dist"
  ],
  "homepage": "https://github.com/pxlprfct/bookmarked#readme",
  "keywords": [
    "bookmark",
    "chrome",
    "firefox",
    "safari"
  ],
  "license": "MIT",
  "main": "dist/index.js",
  "packageManager": "pnpm@10.33.0",
  "repository": "pxlprfct/bookmarked.git",
  "scripts": {
    "build": "tsup",
    "changeset": "changeset",
    "dev": "vitest",
    "exports": "attw --pack .",
    "format": "prettier --check .",
    "format:fix": "prettier --write .",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "release": "changeset version && changeset publish",
    "syncpack:format": "syncpack format",
    "syncpack:update": "syncpack update",
    "test": "vitest",
    "test:coverage": "vitest --coverage",
    "test:ui": "vitest --ui",
    "tsc": "tsc",
    "watch": "pnpm run build -- --watch src",
    "knip": "VITE_CJS_IGNORE_WARNING=true knip"
  },
  "type": "module"
}
